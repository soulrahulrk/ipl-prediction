# Flask security
SECRET_KEY=replace-with-strong-secret
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_TIMEOUT_MINUTES=240
CSRF_ENABLED=true

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ipl_predictor

# Rate limits
RATE_LIMIT_DEFAULT=200 per hour
AUTH_LOGIN_RATE_LIMIT=10 per minute
WRITE_RATE_LIMIT=30 per minute
RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0
# Alternative if your platform exposes REDIS_URL
# REDIS_URL=redis://default:password@host:6379/0

# Monitoring and model storage
MONITORING_STORAGE=database
MODEL_STORAGE_BACKEND=local
MODEL_STORAGE_URI_PREFIX=

# Model versions
SCORE_MODEL_VERSION=local-v1
WIN_MODEL_VERSION=local-v1
